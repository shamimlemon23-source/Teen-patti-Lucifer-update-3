{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "A poker player's persistent data",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The unique name of the player"
        },
        "uid": {
          "type": "string",
          "description": "Unique identifier for the player"
        },
        "chips": {
          "type": "number",
          "description": "The current chip count"
        },
        "last_spin": {
          "type": "number",
          "description": "Timestamp of the last daily spin"
        },
        "last_bonus": {
          "type": "number",
          "description": "Timestamp of the last 6-hour bonus"
        },
        "profilePic": {
          "type": "string",
          "description": "Base64 encoded profile picture"
        },
        "password": {
          "type": "string",
          "description": "Hashed or plain password for security"
        }
      },
      "required": ["name", "uid", "chips"]
    }
  },
  "firestore": {
    "/players/{playerName}": {
      "schema": "Player",
      "description": "Collection of players indexed by their name"
    }
  }
}
