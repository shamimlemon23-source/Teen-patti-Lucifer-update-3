rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: players
    // Document ID: playerName
    // Fields:
    //   - name: string (required)
    //   - chips: number (required)
    //   - last_spin: number (optional)
    //   - password: string (optional)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "shamimlemon23@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }

    match /players/{playerName} {
      // The server uses the JS SDK and is unauthenticated in this environment.
      // To allow the server to manage player data, we allow read/write.
      // In a production app, you would use the Admin SDK or authenticate the server.
      allow read, write: if true;
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
