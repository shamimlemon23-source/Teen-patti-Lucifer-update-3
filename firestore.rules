rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: players
    // Document ID: playerName
    // Fields:
    //   - name: string (required)
    //   - chips: number (required)
    //   - last_spin: number (optional)
    //   - password: string (optional)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "shamimlemon23@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }

    match /players/{playerName} {
      // For this specific app, the server handles most logic.
      // However, we can allow the user to read their own data if they are logged in.
      // But since the app uses Name-based login without Firebase Auth for players,
      // we will rely on the server to be the secure gatekeeper.
      // To allow the server to work, we'll keep rules restrictive for clients.
      
      allow read, write: if isAdmin();
      
      // If we want to allow the server (which might not be using Admin SDK in this environment)
      // to access data, we might need to be careful.
      // But usually, the server in this environment has full access if configured correctly.
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
